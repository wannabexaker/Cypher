// Cypher — data model (source of truth)
// Stack: Next.js 15 + Prisma + PostgreSQL (Neon/Supabase) on Vercel.
// CORE CONCEPT: a Channel is a "room" with a join CODE. A host creates it; whoever enters
// with the code joins as a member and can upload tracks. Host moderates. Crowd votes. Battles decide.
// Voting: guest-allowed (fingerprint + IP cap + Turnstile captcha). See docs/plan 1.md §1b, §4, §6.
//
// Conventions:
//  - Tables snake_case plural via @@map; columns snake_case via @map.
//  - PK id = UUID. FK = {table_singular}_id.
//  - ip_hash / fingerprint_hash = HMAC(server_secret, value). NEVER raw IP/PII.
//  - Vote uniqueness is enforced by the DB UNIQUE on Vote.dedupeKey (final guard), not app code.

generator client {
  provider = "prisma-client-js"
  // "native" covers local dev + the arm64 build container; the explicit arm64
  // target keeps `prisma generate` correct when cross-building the RPi image.
  binaryTargets = ["native", "linux-arm64-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL") // for migrations behind a serverless pooler (Neon/Supabase)
}

// ─────────────────────────────────────────────────────────────────────────────
// Enums
// ─────────────────────────────────────────────────────────────────────────────

enum Role {
  USER
  ADMIN // platform admin (site-wide). Channel-level roles live on ChannelMember.
}

enum MemberRole {
  HOST // creator / admin of the room
  MODERATOR // can help review submissions
  MEMBER // joined via code, can upload + vote
}

// How a non-host member takes part. ARTIST submits a track; JUDGE votes only
// (label-only for now; vote weighting lands later). null for the host.
enum ParticipationType {
  ARTIST
  JUDGE
}

enum ChannelVisibility {
  PUBLIC // listed on /explore
  UNLISTED // code-only, not listed
}

enum ChannelStatus {
  DRAFT
  OPEN // submissions open (artists drop tracks)
  SUBMISSIONS_CLOSED
  VOTING_OPEN
  VOTING_CLOSED
  RESULTS
  BATTLE
  COMPLETED
}

enum ResultsVisibility {
  LIVE // live counts visible to everyone
  HIDDEN // host-only
  AFTER_CLOSE // revealed when voting closes
}

enum VoteScope {
  PER_SUBMISSION // one vote per track per voter
  PER_COMPETITION // one vote total per voter (pick a favorite)
}

enum VoteChoice {
  WIN
  LOSS
}

enum SourceType {
  FILE_MP3
  FILE_WAV
  SOUNDCLOUD
  SPOTIFY
  YOUTUBE
  OTHER_URL
}

enum SubmissionStatus {
  PENDING
  APPROVED
  REJECTED
  DISQUALIFIED
}

enum ScanStatus {
  PENDING
  CLEAN
  INFECTED
}

enum TranscodeStatus {
  PENDING
  DONE
  FAILED
  NOT_REQUIRED
}

enum RoundStatus {
  PENDING
  VOTING_OPEN
  CLOSED
}

enum ResultMode {
  MERGE // sum all track's rounds
  SELECTED // use the advancing round
}

enum MatchupStatus {
  PENDING
  VOTING_OPEN
  DECIDED
}

// H16a: a Contest is a single competition that runs inside a Channel.
// Channels are persistent venues; each Contest captures one round of activity
// (a leaderboard or a battle bracket). Additive in H16a — existing flows still
// keep working without resolving a contest.
enum ContestMode {
  BATTLE
  LEADERBOARD
}

enum ContestStatus {
  DRAFT
  VOTING_OPEN
  COMPLETED
}

// ─────────────────────────────────────────────────────────────────────────────
// Auth (Auth.js / NextAuth Prisma adapter) + app user
// ─────────────────────────────────────────────────────────────────────────────

model User {
  id            String    @id @default(uuid())
  email         String    @unique
  username      String    @unique
  passwordHash  String?   @map("password_hash") // null when OAuth-only
  displayName   String?   @map("display_name")
  avatarUrl     String?   @map("avatar_url")
  role          Role      @default(USER)
  isBanned      Boolean   @default(false) @map("is_banned")
  emailVerified DateTime? @map("email_verified")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  accounts            Account[]
  sessions            Session[]
  hostedChannels      Channel[]       @relation("HostChannels")
  memberships         ChannelMember[]
  mediaAssets         MediaAsset[]
  votes               Vote[]
  reviewedSubmissions Submission[]    @relation("ReviewedBy")
  auditLogs           AuditLog[]

  @@map("users")
}

model Account {
  id                String  @id @default(uuid())
  userId            String  @map("user_id")
  type              String
  provider          String
  providerAccountId String  @map("provider_account_id")
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(uuid())
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id")
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// ─────────────────────────────────────────────────────────────────────────────
// Channel (the "room") + membership
// ─────────────────────────────────────────────────────────────────────────────

model Channel {
  id            String            @id @default(uuid())
  code          String            @unique // shareable join code, e.g. "7K2P9X"
  slug          String?           @unique // optional pretty URL for PUBLIC channels
  name          String
  tagline       String? // room's own hero headline / call (e.g. "Let the chat decide")
  description   String?
  rules         String?
  coverImageUrl String?           @map("cover_image_url")
  genre         String?
  hostId        String            @map("host_id")
  status        ChannelStatus     @default(DRAFT)
  visibility    ChannelVisibility @default(UNLISTED)

  submissionStartAt DateTime? @map("submission_start_at")
  submissionEndAt   DateTime? @map("submission_end_at")
  votingStartAt     DateTime? @map("voting_start_at")
  votingEndAt       DateTime? @map("voting_end_at")

  // H07 host-armed voting window (lazy, just-in-time enforcement; null = open indefinitely)
  votingOpenedAt DateTime? @map("voting_opened_at") // set when the host first arms a window
  votingClosesAt DateTime? @map("voting_closes_at") // the armed deadline; null = no timer

  // H09 finalize: the host crowns a champion and freezes the room.
  championSubmissionId String?   @map("champion_submission_id") // winning track once COMPLETED
  completedAt          DateTime? @map("completed_at") // when the host finalized the room

  // H14 retention: auto-purge cutoff = completedAt + 3 days. Cron deletes
  // channel + MinIO objects once now() >= purgeAfter. Hosts may delete sooner.
  // H16a: superseded by lastActivityAt-based retention (15-day inactivity).
  // Column kept additive — cron no longer reads it.
  purgeAfter DateTime? @map("purge_after")

  // H16a: bumped whenever something happens in the channel (submission,
  // vote, round open/close, finalize). Cron purges channels idle for 15 days.
  lastActivityAt DateTime @default(now()) @map("last_activity_at")

  resultsVisibility  ResultsVisibility @default(AFTER_CLOSE) @map("results_visibility")
  voteScope          VoteScope         @default(PER_SUBMISSION) @map("vote_scope")
  maxVotesPerVoter   Int               @default(1) @map("max_votes_per_voter")
  allowGuestVotes    Boolean           @default(true) @map("allow_guest_votes")
  requireLoginToVote Boolean           @default(false) @map("require_login_to_vote")
  allowGuestUploads  Boolean           @default(false) @map("allow_guest_uploads") // join-with-code + name, no account

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  host              User               @relation("HostChannels", fields: [hostId], references: [id])
  champion          Submission?        @relation("ChannelChampion", fields: [championSubmissionId], references: [id])
  members           ChannelMember[]
  submissions       Submission[]
  votes             Vote[]
  trackVoteRounds   TrackVoteRound[] // H13
  battleRounds      BattleRound[]
  contests          Contest[] // H16a
  pushSubscriptions PushSubscription[]

  @@index([status])
  @@index([hostId])
  @@index([visibility, status])
  @@index([lastActivityAt])
  @@map("channels")
}

// H08 web push: a browser PushManager subscription scoped to one room and one
// member (registered user or signed guest). Endpoint is globally unique so a
// re-subscribe upserts rather than duplicating.
model PushSubscription {
  id         String   @id @default(uuid())
  channelId  String   @map("channel_id")
  endpoint   String   @unique
  p256dh     String
  auth       String
  userId     String?  @map("user_id") // null for guests
  guestToken String?  @map("guest_token") // null for registered users
  userAgent  String?  @map("user_agent")
  createdAt  DateTime @default(now()) @map("created_at")

  channel Channel @relation(fields: [channelId], references: [id], onDelete: Cascade)

  @@index([channelId])
  @@map("push_subscriptions")
}

// A participant in a room. Either a registered user OR a lightweight guest (token + display name).
model ChannelMember {
  id            String             @id @default(uuid())
  channelId     String             @map("channel_id")
  userId        String?            @map("user_id") // set when the member is a registered user
  guestToken    String?            @map("guest_token") // set for code-only guests (signed cookie token)
  displayName   String             @map("display_name")
  role          MemberRole         @default(MEMBER)
  participation ParticipationType? @map("participation") // ARTIST | JUDGE; null for the host
  createdAt     DateTime           @default(now()) @map("created_at")

  channel     Channel      @relation(fields: [channelId], references: [id], onDelete: Cascade)
  user        User?        @relation(fields: [userId], references: [id])
  submissions Submission[]

  @@unique([channelId, userId])
  @@unique([channelId, guestToken])
  @@index([channelId])
  @@map("channel_members")
}

// ─────────────────────────────────────────────────────────────────────────────
// Submissions + media
// ─────────────────────────────────────────────────────────────────────────────

model Submission {
  id                String           @id @default(uuid())
  channelId         String           @map("channel_id")
  submitterMemberId String           @map("submitter_member_id")
  artistName        String           @map("artist_name")
  trackTitle        String           @map("track_title")
  description       String?
  sourceType        SourceType       @map("source_type")
  mediaAssetId      String?          @unique @map("media_asset_id") // for uploads
  externalUrl       String?          @map("external_url") // for embeds
  status            SubmissionStatus @default(PENDING)
  rejectionReason   String?          @map("rejection_reason")
  reviewedById      String?          @map("reviewed_by")
  reviewedAt        DateTime?        @map("reviewed_at")
  voteCount         Int              @default(0) @map("vote_count") // denormalized; truth = count(valid votes)
  winCount          Int              @default(0) @map("win_count")
  lossCount         Int              @default(0) @map("loss_count")
  roundResultMode   ResultMode       @default(MERGE) @map("round_result_mode") // H13: how the track's final is computed
  createdAt         DateTime         @default(now()) @map("created_at")

  channel         Channel              @relation(fields: [channelId], references: [id], onDelete: Cascade)
  championOf      Channel[]            @relation("ChannelChampion")
  submitterMember ChannelMember        @relation(fields: [submitterMemberId], references: [id])
  reviewedBy      User?                @relation("ReviewedBy", fields: [reviewedById], references: [id])
  mediaAsset      MediaAsset?          @relation(fields: [mediaAssetId], references: [id])
  votes           Vote[]
  trackVoteRounds TrackVoteRound[] // H13: voting rounds for this track
  matchupsAsA     Matchup[]            @relation("MatchupSubmissionA")
  matchupsAsB     Matchup[]            @relation("MatchupSubmissionB")
  matchupsWon     Matchup[]            @relation("MatchupWinner")
  contestEntries  ContestParticipant[] // H16a

  @@index([channelId, status])
  @@map("submissions")
}

model MediaAsset {
  id               String          @id @default(uuid())
  ownerUserId      String?         @map("owner_user_id") // null for guest uploads
  storageKey       String          @map("storage_key")
  mimeType         String          @map("mime_type")
  sizeBytes        Int             @map("size_bytes")
  durationSeconds  Int?            @map("duration_seconds")
  originalFilename String?         @map("original_filename")
  scanStatus       ScanStatus      @default(PENDING) @map("scan_status")
  transcodeStatus  TranscodeStatus @default(PENDING) @map("transcode_status")
  previewKey       String?         @map("preview_key")
  createdAt        DateTime        @default(now()) @map("created_at")

  owner      User?       @relation(fields: [ownerUserId], references: [id])
  submission Submission?

  @@map("media_assets")
}

// ─────────────────────────────────────────────────────────────────────────────
// Vote — the crux. Identity = user OR fingerprint (fallback cookie/guest token).
// dedupeKey is computed app-side, namespaced; its UNIQUE is the final anti-double-vote guard:
//   PER_SUBMISSION : "ch:{channelId}:s:{submissionId}:{identity}"
//   PER_COMPETITION: "ch:{channelId}:{identity}"
//   battle track   : "m:{matchupId}:s:{submissionId}:{identity}"
// identity = "u:{userId}" if logged-in, else "f:{fingerprintHash}".
// IP stays OUT of the unique (rate cap only) — NAT/mobile share IPs.
// ─────────────────────────────────────────────────────────────────────────────

model Vote {
  id               String  @id @default(uuid())
  channelId        String  @map("channel_id")
  submissionId     String  @map("submission_id")
  roundId          String? @map("round_id") // BattleRound for battle votes
  matchupId        String? @map("matchup_id") // for battle matchup votes
  trackVoteRoundId String? @map("track_vote_round_id") // H13: for qualifying track votes
  contestId        String? @map("contest_id") // H16a: resolved active contest (nullable for legacy rows)
  voterUserId      String? @map("voter_user_id")

  ipHash          String  @map("ip_hash") // HMAC, rate cap only
  fingerprintHash String? @map("fingerprint_hash") // HMAC, primary guest identity
  cookieToken     String? @map("cookie_token") // signed httpOnly, soft check
  userAgent       String? @map("user_agent")

  dedupeKey String     @map("dedupe_key")
  choice    VoteChoice @map("choice")
  isValid   Boolean    @default(true) @map("is_valid")
  createdAt DateTime   @default(now()) @map("created_at")

  channel        Channel         @relation(fields: [channelId], references: [id], onDelete: Cascade)
  submission     Submission      @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  round          BattleRound?    @relation(fields: [roundId], references: [id])
  matchup        Matchup?        @relation(fields: [matchupId], references: [id])
  trackVoteRound TrackVoteRound? @relation(fields: [trackVoteRoundId], references: [id])
  contest        Contest?        @relation(fields: [contestId], references: [id])
  voter          User?           @relation(fields: [voterUserId], references: [id])

  @@unique([dedupeKey]) // FINAL guard against double-voting (catches races)
  @@index([channelId, isValid])
  @@index([submissionId, isValid])
  @@index([ipHash, channelId])
  @@index([trackVoteRoundId])
  @@index([contestId, isValid])
  @@map("votes")
}

// ─────────────────────────────────────────────────────────────────────────────
// H13 Track voting rounds (per-track multi-round live voting)
// ─────────────────────────────────────────────────────────────────────────────

model TrackVoteRound {
  id              String      @id @default(uuid())
  channelId       String      @map("channel_id")
  submissionId    String      @map("submission_id")
  contestId       String?     @map("contest_id") // H16a: resolved leaderboard contest
  index           Int         @map("index") // 1..5
  status          RoundStatus @default(VOTING_OPEN) @map("status")
  advances        Boolean     @default(false) @map("advances") // host-selected round
  durationSeconds Int?        @map("duration_seconds") // optional countdown
  openedAt        DateTime    @default(now()) @map("opened_at")
  closesAt        DateTime?   @map("closes_at") // openedAt + duration
  closedAt        DateTime?   @map("closed_at")

  channel    Channel    @relation(fields: [channelId], references: [id], onDelete: Cascade)
  submission Submission @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  contest    Contest?   @relation(fields: [contestId], references: [id])
  votes      Vote[]

  @@unique([submissionId, index])
  @@index([channelId, status])
  @@index([contestId])
  @@map("track_vote_rounds")
}

// ─────────────────────────────────────────────────────────────────────────────
// Battle system (single-elimination bracket)
// ─────────────────────────────────────────────────────────────────────────────

model BattleRound {
  id            String      @id @default(uuid())
  channelId     String      @map("channel_id")
  contestId     String?     @map("contest_id") // H16a: resolved battle contest
  roundNumber   Int         @map("round_number")
  name          String? // e.g. "Ημιτελικοί"
  status        RoundStatus @default(PENDING)
  votingStartAt DateTime?   @map("voting_start_at")
  votingEndAt   DateTime?   @map("voting_end_at")

  channel  Channel   @relation(fields: [channelId], references: [id], onDelete: Cascade)
  contest  Contest?  @relation(fields: [contestId], references: [id])
  matchups Matchup[]
  votes    Vote[]

  @@unique([contestId, roundNumber])
  @@index([channelId])
  @@index([contestId])
  @@map("battle_rounds")
}

model Matchup {
  id                 String        @id @default(uuid())
  roundId            String        @map("round_id")
  position           Int           @default(0) @map("position")
  submissionAId      String        @map("submission_a_id")
  submissionBId      String?       @map("submission_b_id") // null = bye
  votesA             Int           @default(0) @map("votes_a")
  votesB             Int           @default(0) @map("votes_b")
  winnerSubmissionId String?       @map("winner_submission_id")
  status             MatchupStatus @default(PENDING)

  round       BattleRound @relation(fields: [roundId], references: [id], onDelete: Cascade)
  submissionA Submission  @relation("MatchupSubmissionA", fields: [submissionAId], references: [id])
  submissionB Submission? @relation("MatchupSubmissionB", fields: [submissionBId], references: [id])
  winner      Submission? @relation("MatchupWinner", fields: [winnerSubmissionId], references: [id])
  votes       Vote[]

  @@index([roundId])
  @@map("matchups")
}

// ─────────────────────────────────────────────────────────────────────────────
// H16a Contest: a single competition that runs inside a Channel.
// A Channel is the persistent venue; each Contest is one round of activity
// (LEADERBOARD = open submissions + votes; BATTLE = single-elim bracket).
// Per-mode stats aggregate from ContestParticipant.wins/losses; live counters
// on Submission still mirror the active contest in H16a.
// ─────────────────────────────────────────────────────────────────────────────

model Contest {
  id                   String            @id @default(uuid())
  channelId            String            @map("channel_id")
  mode                 ContestMode
  status               ContestStatus     @default(DRAFT)
  // H20a: per-channel-per-mode sequence (1-based). Computed at create time
  // inside the create transaction so concurrent contests still get unique
  // numbers; nullable for the duration of the backfill migration window.
  number               Int?
  bracketSize          Int?              @map("bracket_size") // BATTLE only
  title                String?
  votingClosesAt       DateTime?         @map("voting_closes_at")
  championSubmissionId String?           @map("champion_submission_id")
  rankingSnapshot      Json?             @map("ranking_snapshot")
  resultsVisibility    ResultsVisibility @default(AFTER_CLOSE) @map("results_visibility")
  createdAt            DateTime          @default(now()) @map("created_at")
  completedAt          DateTime?         @map("completed_at")

  channel         Channel              @relation(fields: [channelId], references: [id], onDelete: Cascade)
  participants    ContestParticipant[]
  votes           Vote[]
  trackVoteRounds TrackVoteRound[]
  battleRounds    BattleRound[]

  @@index([channelId, mode, status])
  @@map("contests")
}

model ContestParticipant {
  id              String @id @default(uuid())
  contestId       String @map("contest_id")
  submissionId    String @map("submission_id")
  seed            Int?
  wins            Int    @default(0)
  losses          Int    @default(0)
  rank            Int?
  eliminatedRound Int?   @map("eliminated_round")

  contest    Contest    @relation(fields: [contestId], references: [id], onDelete: Cascade)
  submission Submission @relation(fields: [submissionId], references: [id], onDelete: Cascade)

  @@unique([contestId, submissionId])
  @@index([submissionId])
  @@map("contest_participants")
}

// ─────────────────────────────────────────────────────────────────────────────
// Audit trail
// ─────────────────────────────────────────────────────────────────────────────

model AuditLog {
  id          String   @id @default(uuid())
  actorUserId String?  @map("actor_user_id")
  action      String // e.g. "vote.cast", "submission.approve", "channel.transition", "member.join"
  entityType  String   @map("entity_type")
  entityId    String   @map("entity_id")
  metadata    Json?
  ipHash      String?  @map("ip_hash")
  createdAt   DateTime @default(now()) @map("created_at")

  actor User? @relation(fields: [actorUserId], references: [id])

  @@index([entityType, entityId])
  @@index([actorUserId])
  @@map("audit_logs")
}
