DATABASE_URL="postgresql://cypher:cypher@localhost:5432/cypher?schema=public"
DIRECT_URL="postgresql://cypher:cypher@localhost:5432/cypher?schema=public"
AUTH_SECRET="generate-with: openssl rand -base64 33"

# Optional OAuth. Leave both empty to disable Google sign-in.
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# Required in production for registration and guest voting. Leave empty only
# for local development and tests.
TURNSTILE_SECRET_KEY=""
NEXT_PUBLIC_TURNSTILE_SITE_KEY=""

# Required in production. Upstash REST-backed sliding-window rate limits for
# login, registration, joins, uploads, and voting. Optional in local dev/tests.
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# Basic per-channel database cap for distinct votes sharing one IP hash.
VOTE_IP_CAP="40"

# S3-compatible object storage (PRIVATE bucket).
# Local dev = MinIO (docker-compose). Prod target = Cloudflare R2.
S3_ENDPOINT="http://localhost:9000"
S3_REGION="auto"
S3_BUCKET="cypher-media"
S3_ACCESS_KEY_ID="minioadmin"
S3_SECRET_ACCESS_KEY="minioadmin"
# true for MinIO/path-style; false for virtual-hosted (most R2 setups).
S3_FORCE_PATH_STYLE="true"
# TTL (seconds) for signed media GET URLs.
MEDIA_URL_TTL_SECONDS="300"

# Production malware scanner. Cypher POSTs metadata plus a short-lived signed
# media URL and expects {"verdict":"clean"} or {"verdict":"infected"}.
# HTTPS + bearer token are mandatory in production. Local/test may leave empty
# and rely on the existing size/MIME/magic-byte validation only.
MALWARE_SCAN_URL=""
MALWARE_SCAN_TOKEN=""
MALWARE_SCAN_TIMEOUT_MS="25000"

# Daily cleanup age for unlinked MediaAsset rows and DB-less media/ objects.
MEDIA_ORPHAN_TTL_HOURS="24"

# H08 web push (VAPID). Leave empty to disable push entirely (opt-in UI hidden,
# sendChannelPush becomes a no-op). Generate a keypair with:
#   corepack pnpm exec web-push generate-vapid-keys
# VAPID_PUBLIC_KEY and NEXT_PUBLIC_VAPID_PUBLIC_KEY MUST hold the same value;
# only the public key is exposed to the browser. Never expose the private key.
VAPID_PUBLIC_KEY=""
VAPID_PRIVATE_KEY=""
VAPID_SUBJECT="mailto:admin@example.com"
NEXT_PUBLIC_VAPID_PUBLIC_KEY=""

# Retention and media-maintenance crons. Vercel cron sends GET requests with
#   Authorization: Bearer <CRON_SECRET>
# Generate with: openssl rand -hex 32
CRON_SECRET=""

