# Cypher — production env for the self-hosted Raspberry Pi stack.
# Copy to `.env.production` and fill real values. NEVER commit `.env.production`.
# `<domain>` = your app domain, `<media-domain>` = the storage subdomain
# (both must be public hostnames routed by the Cloudflare Tunnel).

# ── Database (internal Postgres container) ──────────────────────────────────
POSTGRES_DB="cypher"
POSTGRES_USER="cypher"
POSTGRES_PASSWORD="CHANGE-ME-strong-db-password"
DATABASE_URL="postgresql://cypher:CHANGE-ME-strong-db-password@postgres:5432/cypher?schema=public"
DIRECT_URL="postgresql://cypher:CHANGE-ME-strong-db-password@postgres:5432/cypher?schema=public"

# ── Auth.js ─────────────────────────────────────────────────────────────────
AUTH_SECRET="CHANGE-ME: openssl rand -base64 33"
AUTH_URL="https://<domain>"
NEXTAUTH_URL="https://<domain>"
AUTH_TRUST_HOST="true"
# Optional Google login (leave empty to disable). Redirect URI:
#   https://<domain>/api/auth/callback/google
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# ── Object storage (internal MinIO, browser-reachable via <media-domain>) ────
# S3_ENDPOINT MUST be the PUBLIC media hostname — the browser fetches presigned
# URLs from it. The Cloudflare Tunnel routes <media-domain> -> minio:9000.
S3_ENDPOINT="https://<media-domain>"
S3_REGION="auto"
S3_BUCKET="cypher-media"
S3_ACCESS_KEY_ID="cypher-minio"
S3_SECRET_ACCESS_KEY="CHANGE-ME-strong-minio-secret"
S3_FORCE_PATH_STYLE="true"
MEDIA_URL_TTL_SECONDS="300"

# ── Rate limiting (self-hosted Redis via serverless-redis-http) ─────────────
# SRH speaks the Upstash REST protocol so the app code is unchanged.
# The token here MUST equal SRH_TOKEN on the srh service.
UPSTASH_REDIS_REST_URL="http://srh:80"
UPSTASH_REDIS_REST_TOKEN="CHANGE-ME-strong-srh-token"
VOTE_IP_CAP="40"

# ── Anti-bot (Cloudflare Turnstile — cloud, free) ───────────────────────────
TURNSTILE_SECRET_KEY=""
NEXT_PUBLIC_TURNSTILE_SITE_KEY=""

# ── Malware scanner (internal ClamAV wrapper over self-signed TLS) ──────────
# Internal-only https (never exposed). The app trusts the cert via
# NODE_EXTRA_CA_CERTS (wired in docker-compose.prod.yml). The token MUST equal
# SCANNER_TOKEN on the scanner service.
MALWARE_SCAN_URL="https://scanner:8443"
MALWARE_SCAN_TOKEN="CHANGE-ME-strong-scanner-token"
MALWARE_SCAN_TIMEOUT_MS="25000"
MEDIA_ORPHAN_TTL_HOURS="24"

# ── Cron (internal scheduler hits /api/cron/* with this bearer) ─────────────
CRON_SECRET="CHANGE-ME: openssl rand -hex 32"

# ── Web push (optional; leave empty to disable) ─────────────────────────────
# Generate: corepack pnpm exec web-push generate-vapid-keys
VAPID_PUBLIC_KEY=""
VAPID_PRIVATE_KEY=""
VAPID_SUBJECT="mailto:admin@<domain>"
NEXT_PUBLIC_VAPID_PUBLIC_KEY=""

# ── Ops alerts (optional; R04 cron failure/degraded webhook) ────────────────
OPS_ALERT_WEBHOOK_URL=""

# ── Cloudflare Tunnel ───────────────────────────────────────────────────────
# From the Zero Trust dashboard tunnel you create (see docs/deploy/RPI.md).
CLOUDFLARE_TUNNEL_TOKEN="CHANGE-ME-tunnel-token"
